# Skopiuj ten plik do  server/.env  i uzupelnij klucz.
# Funkcje AI (TL;DR, dzienny digest) wlaczaja sie automatycznie, gdy klucz jest obecny.

# Klucz API z https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Model uzywany do streszczen i digestu.
# Domyslnie claude-opus-4-8 (najlepsza jakosc).
# Dla taniego/szybkiego masowego streszczania ustaw: claude-haiku-4-5
AI_MODEL=claude-opus-4-8
