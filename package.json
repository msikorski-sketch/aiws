{
  "name": "ai-daily",
  "version": "1.0.0",
  "private": true,
  "description": "AI Daily — a daily.dev-style news aggregator focused exclusively on Artificial Intelligence.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c magenta,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix client install",
    "build": "npm --prefix client run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@mozilla/readability": "^0.6.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsdom": "^29.1.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
